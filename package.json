{
  "name": "greenlight",
  "version": "0.1.0",
  "description": "Zero-friction auto-approval daemon for Claude Code permission prompts",
  "author": "hvrcharon1",
  "license": "MIT",
  "bin": {
    "greenlight": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "assets/logo.svg",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "node-pty": "^1.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.14.0",
    "@typescript-eslint/parser": "^7.14.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "auto-approve",
    "ai-agent",
    "developer-tools",
    "automation",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hvrcharon1/greenlight.git"
  },
  "bugs": {
    "url": "https://github.com/hvrcharon1/greenlight/issues"
  },
  "homepage": "https://github.com/hvrcharon1/greenlight#readme"
}
